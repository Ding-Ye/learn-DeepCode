{
  "agents": {
    "defaults": {
      "provider": "auto",
      "model": "openai/gpt-5.4",
      "maxTokens": 40000,
      "temperature": 0.1
    },
    "planning": {
      "model": "anthropic/claude-sonnet-4-20250514",
      "maxTokens": 32000
    },
    "implementation": {
      "temperature": 0.2
    }
  },

  "providers": {
    "openai": {
      "apiKey": "${OPENAI_API_KEY}"
    },
    "anthropic": {
      "apiKey": "literal-anthropic-key",
      "apiBase": "https://api.anthropic.com"
    }
  },

  "tools": {
    "defaultSearchServer": "filesystem"
  },

  "workspace": {
    "root": "./deepcode_lab",
    "maxInputMb": 100
  },

  "documentSegmentation": {
    "enabled": true,
    "sizeThresholdChars": 50000
  },

  "logger": {
    "level": "info",
    "transports": ["console", "global_file", "task_file"]
  }
}
